# This file belongs in an nginx `http` context, such as /etc/nginx/conf.d/.
limit_req_zone $binary_remote_addr zone=toki_hub_uploads:10m rate=120r/m;
limit_req_zone $binary_remote_addr zone=toki_hub_owner:10m rate=60r/m;
limit_req_zone $binary_remote_addr zone=toki_hub_snapshot_reads:10m rate=60r/m;
limit_req_zone $binary_remote_addr zone=toki_hub_bulk_snapshot_reads:10m rate=2r/m;
limit_conn_zone $binary_remote_addr zone=toki_hub_connections:10m;

server {
    listen 80;
    listen [::]:80;
    server_name hub.example.com;
    return 301 https://hub.example.com$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name hub.example.com;
    server_tokens off;

    ssl_certificate /etc/letsencrypt/live/hub.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/hub.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    client_max_body_size 64k;
    client_body_timeout 20s;
    keepalive_timeout 30s;
    access_log off;

    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Content-Type-Options "nosniff" always;

    location ~ ^/v1/devices/[A-Za-z0-9_-]+/snapshot$ {
        client_max_body_size 8m;
        limit_req zone=toki_hub_uploads burst=128 nodelay;
        limit_conn toki_hub_connections 10;
        include /etc/nginx/toki-hub-proxy.inc;
    }

    location ~ ^/v1/devices/[A-Za-z0-9_-]+/heartbeat$ {
        limit_req zone=toki_hub_uploads burst=128 nodelay;
        limit_conn toki_hub_connections 10;
        include /etc/nginx/toki-hub-proxy.inc;
    }

    location = /v1/snapshots {
        limit_req zone=toki_hub_bulk_snapshot_reads burst=1 nodelay;
        limit_conn toki_hub_connections 1;
        include /etc/nginx/toki-hub-proxy.inc;
    }

    location ~ ^/v1/snapshots(?:/manifest|/[A-Za-z0-9_-]+)$ {
        limit_req zone=toki_hub_snapshot_reads burst=65 nodelay;
        limit_conn toki_hub_connections 10;
        include /etc/nginx/toki-hub-proxy.inc;
    }

    location / {
        limit_req zone=toki_hub_owner burst=20 nodelay;
        limit_conn toki_hub_connections 10;
        include /etc/nginx/toki-hub-proxy.inc;
    }
}
